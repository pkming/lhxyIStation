<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <application
        android:name=".ShellTinkerApplication"
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.IStationShell">
        <meta-data
            android:name="TINKER_ID"
            android:value="${TINKER_ID}" />

        <service
            android:name=".ShellTinkerResultService"
            android:exported="false" />

        <activity
            android:name=".menu.LegacyMenuActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".sysinfo.LegacySystemInfoActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".station.LegacySiteCollectionActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".setup.LegacyBasicSetupActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".info.LegacyInfoBrowsActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".dispatch.LegacyDispatchCenterActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".media.LegacyVoiceCallActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".media.LegacyVideoMonitorActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".file.LegacyFileManageActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".line.LegacyLineChoiceActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".auth.LegacyLoginActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".auth.LegacyPasswordActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".home.LegacyMainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".menu.BusinessModulesActivity"
            android:exported="false" />
        <activity
            android:name=".menu.ModuleCenterActivity"
            android:exported="false" />
        <activity
            android:name=".home.MainActivity"
            android:exported="false" />
    </application>

</manifest>
