<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/rlToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <include layout="@layout/toolbar" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/d_1"
        android:layout_below="@id/rlToolbar"
        android:background="@color/c_ffffff" />


    <RadioGroup
        android:id="@+id/rg_radio_setup_navigation"
        android:layout_width="@dimen/d_130"
        android:layout_height="wrap_content"
        android:layout_below="@id/rlToolbar"
        android:layout_marginLeft="@dimen/d_6"
        android:layout_marginTop="@dimen/d_6"
        android:layout_marginRight="@dimen/d_6"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rb_radio_newspaper"
            android:layout_width="match_parent"
            android:layout_height="@dimen/d_58"
            android:background="@drawable/tabbar_bg"
            android:button="@null"
            android:drawablePadding="@dimen/d_5"
            android:gravity="center"
            android:text="@string/basic_setup_newspaper"
            android:textColor="@drawable/radio_button_selector"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/rb_radio_network"
            android:layout_width="match_parent"
            android:layout_height="@dimen/d_58"
            android:layout_marginTop="@dimen/d_6"
            android:background="@drawable/tabbar_bg"
            android:button="@null"
            android:drawablePadding="@dimen/d_5"
            android:gravity="center"
            android:text="@string/basic_setup_network"
            android:textColor="@drawable/radio_button_selector"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/rb_radio_serial_port"
            android:layout_width="match_parent"
            android:layout_height="@dimen/d_58"
            android:layout_marginTop="@dimen/d_6"
            android:background="@drawable/tabbar_bg"
            android:button="@null"
            android:drawablePadding="@dimen/d_5"
            android:gravity="center"
            android:text="@string/basic_setup_serial_port"
            android:textColor="@drawable/radio_button_selector"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/rb_radio_tts"
            android:layout_width="match_parent"
            android:layout_height="@dimen/d_58"
            android:layout_marginTop="@dimen/d_6"
            android:background="@drawable/tabbar_bg"
            android:button="@null"
            android:drawablePadding="@dimen/d_5"
            android:gravity="center"
            android:text="@string/basic_setup_tts"
            android:textColor="@drawable/radio_button_selector"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/rb_radio_language"
            android:layout_width="match_parent"
            android:layout_height="@dimen/d_58"
            android:layout_marginTop="@dimen/d_6"
            android:background="@drawable/tabbar_bg"
            android:button="@null"
            android:drawablePadding="@dimen/d_5"
            android:gravity="center"
            android:text="@string/basic_setup_language"
            android:textColor="@drawable/radio_button_selector"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/rb_radio_other"
            android:layout_width="match_parent"
            android:layout_height="@dimen/d_58"
            android:layout_marginTop="@dimen/d_6"
            android:background="@drawable/tabbar_bg"
            android:button="@null"
            android:drawablePadding="@dimen/d_5"
            android:gravity="center"
            android:text="@string/basic_setup_other"
            android:textColor="@drawable/radio_button_selector"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/rb_radio_wireless"
            android:layout_width="match_parent"
            android:layout_height="@dimen/d_58"
            android:layout_marginTop="@dimen/d_6"
            android:background="@drawable/tabbar_bg"
            android:button="@null"
            android:drawablePadding="@dimen/d_5"
            android:gravity="center"
            android:text="@string/basic_setup_wireless"
            android:textColor="@drawable/radio_button_selector"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RadioGroup>

    <View
        android:layout_width="@dimen/d_1"
        android:layout_height="match_parent"
        android:layout_below="@id/rlToolbar"
        android:layout_toRightOf="@id/rg_radio_setup_navigation"
        android:background="@color/c_ffffff"
        tools:ignore="all" />

    <FrameLayout
        android:id="@+id/flSetupContext"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/rlToolbar"
        android:layout_toRightOf="@id/rg_radio_setup_navigation"
        android:paddingLeft="@dimen/d_10"
        android:paddingRight="@dimen/d_0"
        tools:ignore="all">

    </FrameLayout>

</RelativeLayout>
