<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/rlToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <include layout="@layout/toolbar" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/rlLineInfoTitle"
        android:layout_width="match_parent"
        android:layout_height="@dimen/d_62"
        android:layout_below="@id/rlToolbar"
        android:background="@color/c_66cdaa"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/d_16"
            android:text="@string/line_line_name"
            android:textColor="@color/c_333333"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:ignore="all" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginLeft="@dimen/d_16"
            android:layout_marginRight="@dimen/d_0"
            tools:ignore="all"
            android:text="@string/line_line_info"
            android:textColor="@color/c_333333"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            tools:ignore="all"
            android:layout_centerVertical="true"
            android:layout_marginRight="@dimen/d_16"
            android:text="@string/line_line_attribute"
            android:textColor="@color/c_333333"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <View
        android:id="@+id/vLineList"
        android:layout_width="match_parent"
        android:layout_height="@dimen/d_1"
        android:layout_below="@id/rlLineInfoTitle"
        android:background="@color/c_ffffff" />

    <RelativeLayout
        android:id="@+id/rlAffirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:paddingBottom="@dimen/d_10">

        <Button
            android:id="@+id/butAffirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/d_30"
            android:layout_marginTop="@dimen/d_10"
            android:layout_marginRight="@dimen/d_30"
            android:layout_marginBottom="@dimen/d_16"
            android:background="@drawable/btn_login_bg"
            android:text="@string/affirm"
            android:textColor="@color/c_000000"
            android:textSize="24sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ListView
        android:id="@+id/lvLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/rlAffirm"
        android:layout_below="@id/vLineList" />

    <LinearLayout
        android:id="@+id/lyNotLine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvLineTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/line_not_tip"
            android:textColor="@color/c_ffffff"
            android:textSize="24sp" />
    </LinearLayout>
</RelativeLayout>
